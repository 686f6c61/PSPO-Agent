{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__trello-client__.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-env.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-gitignore.sh"
          }
        ]
      }
    ]
  }
}
