# Credenciales de Trello
# Se configuran automaticamente mediante el asistente de onboarding del plugin
# Para obtenerlas manualmente: https://trello.com/power-ups/admin

# API Key: identifica la aplicacion (32 caracteres hexadecimales)
# Se obtiene al crear un Power-Up en https://trello.com/power-ups/admin
TRELLO_API_KEY=

# Token: autoriza al plugin a actuar en nombre del usuario
# Se genera en: https://trello.com/1/authorize?expiration=30days&name=PSPO+Agent&scope=read,write&response_type=token&key=TU_API_KEY
TRELLO_TOKEN=

# Fecha de creacion del token (YYYY-MM-DD)
# Gestionada automaticamente por el plugin para calcular la expiracion (30 dias)
TRELLO_TOKEN_CREATED=

# ID del tablero de Trello donde se publican las historias
# Se configura automaticamente durante el onboarding (seleccion o creacion de tablero)
TRELLO_BOARD_ID=

# ---------------------------------------------------------------------------
# Notion (base zero-template desde API)
# ---------------------------------------------------------------------------

# Token de integracion interna de Notion
# La integracion debe tener acceso a la pagina padre donde PSPO Agent creara
# la raiz del proyecto y la base de backlog.
NOTION_TOKEN=

# ID de la pagina padre de Notion donde se creara el proyecto desde cero.
# Formato habitual: UUID con o sin guiones.
NOTION_PARENT_PAGE_ID=

# Opcional: database ya existente para publicar historias sin recrear backlog.
NOTION_DATABASE_ID=

# Opcional: pagina raiz ya creada por PSPO Agent para re-publicaciones.
NOTION_PROJECT_PAGE_ID=

# Opcional: pagina HU-00 ya creada por PSPO Agent para resync de vision.
NOTION_VISION_PAGE_ID=

# ---------------------------------------------------------------------------
# GitHub Projects v2 (Project privado de usuario desde la API)
# ---------------------------------------------------------------------------

# Backend primario: la CLI `gh` autenticada (gh auth login). Si `gh` esta
# autenticado con el scope `project`, no hace falta definir ningun token aqui.
# Si falta el scope: gh auth refresh -s project

# Token personal de GitHub como fallback si no usas la CLI `gh`.
# Necesita el scope `project` (control total) para crear proyectos y escribir
# items en Projects v2. `read:project` es solo lectura y no basta.
GITHUB_TOKEN=

# Alias equivalente a GITHUB_TOKEN (se usa el primero que tenga valor).
GH_TOKEN=

# Numero del Project v2 del usuario donde se publican las historias.
# Se configura automaticamente durante el onboarding (create-project).
GITHUB_PROJECT_NUMBER=

# ID de nodo (node id) del Project v2. Se guarda automaticamente al crearlo.
GITHUB_PROJECT_ID=

# Login del usuario propietario del Project v2.
GITHUB_PROJECT_OWNER=

# URL publica del Project v2 para referencias rapidas.
GITHUB_PROJECT_URL=
