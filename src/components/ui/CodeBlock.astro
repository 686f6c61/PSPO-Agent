---
/**
 * Bloque de codigo con boton de copiar al portapapeles.
 *
 * Renderiza un <pre><code> con el lenguaje indicado. Muestra un boton
 * "Copiar" que aparece al hacer hover y usa la Clipboard API para copiar
 * el contenido. El feedback visual (Copiado / Error) se gestiona en
 * src/scripts/code-block.ts.
 *
 * La etiqueta opcional (label) se muestra encima del bloque en fuente
 * monoespaciada; util para indicar el nombre del fichero.
 */
interface Props {
  code: string;
  language?: string;
  label?: string;
}

const { code, language = 'bash', label } = Astro.props;
---

<div class="code-shell group" data-code-block>
  <div class="code-shell__header">
    <div class="code-shell__lights" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <div class="code-shell__meta">
      {label && <span class="code-shell__label">{label}</span>}
      <span class="code-shell__language">{language}</span>
    </div>
  </div>
  <div class="code-shell__body relative">
    <pre class="code-shell__pre !pr-16"><code class={`language-${language}`}>{code}</code></pre>
    <button
      data-copy-button
      type="button"
      class="code-shell__copy absolute right-3 top-3 rounded-full px-3 py-1.5 text-xs font-medium opacity-100 transition hover:-translate-y-0.5 group-hover:opacity-100"
      aria-label="Copiar codigo al portapapeles"
      aria-live="polite"
    >
      Copiar
    </button>
  </div>
</div>

<script>
  import '../../scripts/code-block';
</script>
