---
/**
 * Cabecera de seccion reutilizable.
 *
 * Renderiza un h2 con el id de ancla de la seccion y, opcionalmente, un
 * parrafo de subtitulo. Se usa en todas las secciones principales de la
 * onepage para mantener coherencia visual y semantica de encabezados.
 */
interface Props {
  title: string;
  subtitle?: string;
  id: string;
}

const { title, subtitle, id } = Astro.props;
---

<div class="mb-12 text-center">
  <h2 id={id} class="text-3xl font-bold tracking-tight text-text-primary sm:text-4xl">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-4 max-w-2xl mx-auto text-lg text-text-secondary leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
