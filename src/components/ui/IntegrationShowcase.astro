---
import { activeIntegrations, upcomingIntegrations } from '../../data/integrations';

interface Props {
  theme?: 'light' | 'dark';
  compact?: boolean;
}

const { theme = 'light', compact = false } = Astro.props;

const isDark = theme === 'dark';
const shellClass = isDark
  ? 'rounded-[1.5rem] border border-white/10 bg-white/[0.04] p-4 sm:p-5'
  : 'rounded-[1.5rem] border border-primary-200/70 bg-white/88 p-4 shadow-sm backdrop-blur sm:p-5';
const titleClass = isDark ? 'text-slate-100' : 'text-text-primary';
const cardClass = isDark
  ? 'border-white/10 bg-slate-900/55'
  : 'border-surface-200 bg-surface-50/85';
const subtitleClass = isDark ? 'text-slate-400' : 'text-text-secondary';
const upcomingClass = isDark
  ? 'border-white/10 bg-white/[0.06] text-slate-200'
  : 'border-surface-200 bg-white text-text-secondary';
---

<div class={shellClass}>
  <div class:list={[
    'grid gap-3',
    compact ? 'sm:grid-cols-2' : 'md:grid-cols-2',
  ]}>
    {activeIntegrations.map((integration) => (
      <div class={`rounded-2xl border p-4 ${cardClass}`}>
        <div class="flex items-center justify-center">
          {integration.logo && (
            <div class={`flex h-12 w-28 items-center justify-center rounded-xl px-3 py-2 shadow-sm ${
              isDark ? 'border border-white/10 bg-white' : 'border border-surface-200 bg-white'
            }`}>
              <img
                src={integration.logo}
                alt={`Logo de ${integration.name}`}
                class={`w-auto ${integration.id === 'notion' ? 'max-h-7' : 'max-h-6'}`}
                loading="lazy"
              />
            </div>
          )}
          {!integration.logo && <div class={`text-sm font-semibold ${titleClass}`}>{integration.name}</div>}
        </div>
      </div>
    ))}
  </div>

  <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-center">
    <div class={`text-xs font-medium uppercase tracking-[0.16em] ${subtitleClass}`}>En breve</div>
    <div class="flex flex-wrap justify-center gap-2">
      {upcomingIntegrations.map((integration) => (
        <span class={`rounded-full border px-3 py-1 text-xs font-medium ${upcomingClass}`}>{integration.name}</span>
      ))}
    </div>
  </div>
</div>
