---
/**
 * Tarjeta de funcionalidad del plugin.
 *
 * Layout horizontal: icono a la izquierda, contenido a la derecha.
 * Barra de acento degradada en la parte superior. Comando con icono
 * de terminal y referencia HU como badge.
 */
interface Props {
  title: string;
  description: string;
  command: string;
  icon: string;
  huReference: string;
}

const { title, description, command, icon, huReference } = Astro.props;
---

<article class="group relative overflow-hidden rounded-xl border border-surface-200 bg-white transition-all hover:shadow-lg hover:border-primary-200">
  <div class="h-0.5 bg-gradient-to-r from-primary-400 via-primary-500 to-primary-600" aria-hidden="true"></div>
  <div class="p-6">
    <div class="flex items-start gap-4">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary-50 ring-1 ring-primary-200/60 transition-colors group-hover:bg-primary-100">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="h-5 w-5 text-primary-600"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
        </svg>
      </div>
      <div class="min-w-0 flex-1">
        <h3 class="text-base font-semibold text-text-primary">{title}</h3>
        <p class="mt-1.5 text-sm text-text-secondary leading-relaxed">{description}</p>
        {(command || huReference) && (
          <div class="mt-3 flex flex-wrap items-center gap-2">
            {command && (
              <code class="inline-flex items-center gap-1.5 rounded-md bg-surface-100 px-2.5 py-1 font-mono text-xs text-text-muted">
                <svg class="h-3 w-3 text-primary-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3" />
                </svg>
                {command}
              </code>
            )}
            {huReference && (
              <span class="rounded-full bg-gradient-to-r from-primary-600 to-primary-700 px-2.5 py-0.5 text-xs font-semibold text-white shadow-sm">{huReference}</span>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</article>
