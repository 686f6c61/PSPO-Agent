---
/**
 * Seccion CTA final antes del footer.
 *
 * Accion principal: instalar el plugin.
 * Accion secundaria: descargar plantilla CSV de equipo.
 */
import CodeBlock from '../ui/CodeBlock.astro';
---

<section id="cta" class="py-16 sm:py-24 bg-surface-50">
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <!-- Instalacion -->
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-text-primary sm:text-4xl">
        Instala PSPO Agent en 30 segundos
      </h2>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
        Un comando, sin dependencias externas. Solo necesitas Python 3 y Claude Code.
      </p>
    </div>

    <div class="max-w-2xl mx-auto space-y-4">
      <CodeBlock
        code="curl -fsSL https://raw.githubusercontent.com/686f6c61/PSPO-Agent/main/install.sh | bash"
        language="bash"
        label="Linux / macOS"
      />
      <CodeBlock
        code="irm https://raw.githubusercontent.com/686f6c61/PSPO-Agent/main/install.ps1 | iex"
        language="powershell"
        label="Windows (PowerShell)"
      />
    </div>

    <!-- Equipo -->
    <div class="mt-12 max-w-2xl mx-auto rounded-xl border border-surface-200 bg-white p-6 shadow-sm text-center">
      <div class="flex justify-center mb-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100">
          <svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0z" />
          </svg>
        </div>
      </div>
      <h3 class="text-lg font-semibold text-text-primary">Configura tu equipo</h3>
      <p class="mt-2 text-sm text-text-secondary leading-relaxed max-w-lg mx-auto">
        Descarga la plantilla CSV, rellena los datos de tu equipo (nombre, email, rol,
        dedicacion, si usan agentes IA) y cargala con
        <code class="rounded bg-surface-100 px-1.5 py-0.5 text-xs font-mono text-text-primary">/pspo-agent:team</code>.
        El plugin enviara las invitaciones al tablero de Trello a cada miembro usando su email.
      </p>
      <div class="mt-4">
        <a
          href="/team-template.csv"
          download="team-template.csv"
          class="inline-flex items-center gap-2 rounded-lg bg-primary-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors hover:bg-primary-700"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Descargar plantilla de equipo (CSV)
        </a>
      </div>
    </div>
  </div>
</section>
