---
/**
 * Seccion CTA final antes del footer.
 *
 * Dos acciones principales:
 * 1. Descargar plantilla de ejemplo (artefactos que genera el plugin)
 * 2. Compartir con el equipo (copiar enlace al portapapeles)
 */
---

<section id="cta" class="py-16 sm:py-24 bg-gradient-to-br from-primary-600 via-primary-700 to-primary-800 relative overflow-hidden">
  <!-- Patron decorativo -->
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <svg class="h-full w-full" viewBox="0 0 800 400" fill="none">
      <circle cx="200" cy="100" r="180" stroke="white" stroke-width="1" />
      <circle cx="600" cy="300" r="220" stroke="white" stroke-width="1" />
      <circle cx="700" cy="50" r="120" stroke="white" stroke-width="1" />
    </svg>
  </div>

  <div class="relative mx-auto max-w-4xl px-4 sm:px-6 text-center">
    <h2 class="text-3xl font-bold text-white sm:text-4xl">
      Prueba PSPO Agent con tu equipo
    </h2>
    <p class="mt-4 text-lg text-primary-100 max-w-2xl mx-auto">
      Descarga una plantilla de ejemplo para ver la calidad de los artefactos que genera el plugin,
      o comparte esta página con tu equipo para empezar juntos.
    </p>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <!-- Descargar plantilla -->
      <a
        href="/plantilla-ejemplo.md"
        download="pspo-agent-plantilla-ejemplo.md"
        class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-primary-700 shadow-lg transition-all hover:bg-primary-50 hover:shadow-xl"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Descargar plantilla de ejemplo
      </a>

      <!-- Invitar al equipo -->
      <button
        data-share-button
        type="button"
        class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20 hover:border-white/50"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
        </svg>
        Invitar al equipo
      </button>
    </div>

    <!-- Feedback de copiado -->
    <div data-share-feedback class="mt-4 hidden text-sm text-primary-200 transition-opacity" aria-live="polite">
      Enlace copiado al portapapeles
    </div>
  </div>
</section>

<script>
  const shareBtn = document.querySelector('[data-share-button]');
  const feedback = document.querySelector('[data-share-feedback]');

  shareBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.origin);
      feedback?.classList.remove('hidden');
      setTimeout(() => feedback?.classList.add('hidden'), 3000);
    } catch {
      // Fallback: abrir email con enlace
      const subject = encodeURIComponent('PSPO Agent - Plugin de Product Owner para Claude Code');
      const body = encodeURIComponent(`Mira este plugin para gestionar producto con IA:\n\n${window.location.origin}`);
      window.open(`mailto:?subject=${subject}&body=${body}`);
    }
  });
</script>
