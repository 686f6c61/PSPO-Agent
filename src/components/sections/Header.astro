  flujo: 'M5 12h14M14 7l5 5-5 5',
  instalacion: 'M12 4v12M8 12l4 4 4-4M5 20h14',
  arquitectura: 'M12 2l8 4v8l-8 4-8-4V6z',
  historias: 'M4 6h16M4 12h16M4 18h10',
};

const currentVersion = 'v1.0.3';

const changelog = [
  {
    version: 'v1.0.3',
    date: '15/03/2026',
    sections: [
      {
        title: 'Nuevas funcionalidades',
        icon: 'M12 4v16m8-8H4',
        items: [
          'invite-member devuelve memberId: mapeo directo email->ID',
          'Asignacion real de miembros a tarjetas (ghost incluidos)',
          'Hook anti-curl: bloquea acceso directo a API de Trello',
          'Verificacion post-publicacion de tarjetas',
          'Enrutamiento por sprint: Sprint actual vs Backlog',
        ],
      },
      {
        title: 'Mejoras',
        icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
        items: [
          'Procesamiento en lotes de 5 tarjetas',
          'AskUserQuestion en todos los puntos de decision',
          'Seleccion de tablero interactiva en onboarding',
          'Verificacion de listas antes de crear (sin duplicados)',
          '12 herramientas MCP documentadas en publisher',
        ],
      },
      {
        title: 'Correcciones',
        icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
        items: [
          'Servidor MCP sobrevive a JSON malformado',
          'Reintentos con backoff en timeout de red',
          'Rate limiter en attach-file e invite-member',
          'Sanitizacion de fileName (header injection)',
          'Validacion de email robusta',
          '239 tests (44 end-to-end reales)',
        ],
      },
    ],
  },
  {
    version: 'v1.0.2',
    date: '14/03/2026',
    sections: [
      {
        title: 'Destacado',
        icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
        items: [
          'Agente senior-auditor para auditoria de HU',
          'Flujo autonomo entre fases',
          '3 reglas inquebrantables del publisher',
          'Invitacion automatica de miembros al tablero',
        ],
      },
    ],
  },
  {
    version: 'v1.0.1',
    date: '14/03/2026',
    sections: [
      {
        title: 'Destacado',
        icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
        items: [
          'Agentes requirement-analyst, culture-guardian, sprint-planner',
          'Skills analyze, team, sprint-plan, sprint-review, export',
          'MCP migrado de TypeScript a Python puro (0 dependencias)',
          'Factor de productividad IA (65% defecto, 70% recomendado)',
