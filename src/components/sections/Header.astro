];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-all duration-300 data-[scrolled]:border-surface-200/80 data-[scrolled]:bg-white/90 data-[scrolled]:backdrop-blur-md" data-header>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6" aria-label="Navegacion principal">
    <a href="#hero" class="flex items-center gap-2 text-lg font-bold text-primary-600 hover:text-primary-700 transition-colors">
      <svg class="h-7 w-7" viewBox="0 0 512 512" fill="none" aria-hidden="true">
        <rect x="2" y="2" width="508" height="508" rx="80" fill="currentColor" />
        <g transform="translate(56, 56) scale(0.78)" stroke="white" fill="none" stroke-width="28" stroke-linecap="round" stroke-linejoin="round">
          <rect x="30" y="60" width="280" height="360" rx="30" />
          <path d="M130 60V40a40 40 0 0 1 80 0v20" />
          <rect x="120" y="20" width="100" height="50" rx="12" />
          <line x1="90" y1="160" x2="260" y2="160" stroke-width="22" />
          <line x1="90" y1="210" x2="260" y2="210" stroke-width="22" />
          <line x1="90" y1="260" x2="220" y2="260" stroke-width="22" />
          <line x1="90" y1="310" x2="200" y2="310" stroke-width="22" />
          <circle cx="240" cy="360" r="55" fill="currentColor" />
          <path d="M215 360l18 18 35-35" stroke-width="22" />
          <path d="M340 200h60v200h60" />
          <path d="M400 280h60" />
          <rect x="450" y="180" width="40" height="40" rx="6" stroke-width="20" />
          <rect x="450" y="260" width="40" height="40" rx="6" stroke-width="20" />
          <rect x="450" y="380" width="40" height="40" rx="6" stroke-width="20" />
        </g>
      </svg>
      PSPO Agent
    </a>

    <!-- Menu escritorio -->
    <div class="hidden items-center gap-1 md:flex">
      <ul class="flex items-center gap-1" role="list">
        {navigation.map((item) => (
          <li>
            <a
              href={item.href}
              data-nav-link={item.sectionId}
              class="flex items-center gap-1.5 rounded-md px-3 py-2 text-sm font-medium text-text-secondary transition-colors hover:text-primary-600 hover:bg-primary-50 [&.active]:text-primary-600 [&.active]:bg-primary-50"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={navIcons[item.sectionId]} />
              </svg>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="ml-2 h-5 w-px bg-surface-300" aria-hidden="true"></div>

      <!-- Badge de version -->
      <button
        data-changelog-toggle
        class="ml-2 inline-flex items-center gap-1 rounded-full bg-primary-50 px-2.5 py-1 text-xs font-semibold text-primary-700 transition-colors hover:bg-primary-100 cursor-pointer border border-primary-200"
        aria-label="Ver cambios de la version actual"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
        </svg>
        {currentVersion}
      </button>

      <!-- GitHub -->
      <a
        href="https://github.com/686f6c61/PSPO-Agent"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-1 flex items-center justify-center rounded-md p-2 text-text-secondary transition-colors hover:text-text-primary hover:bg-surface-100"
        aria-label="Repositorio en GitHub"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
      </a>
    </div>

    <!-- Boton hamburguesa movil -->
    <div class="flex items-center gap-2 md:hidden">
      <!-- Badge version movil -->
      <button
        data-changelog-toggle
        class="inline-flex items-center gap-1 rounded-full bg-primary-50 px-2 py-0.5 text-xs font-semibold text-primary-700 border border-primary-200"
        aria-label="Ver cambios de la version actual"
      >
        {currentVersion}
      </button>
      <button
        data-menu-toggle
        type="button"
        class="inline-flex items-center justify-center rounded-md p-2 text-text-secondary hover:bg-surface-100 hover:text-text-primary"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menu de navegacion"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Menu movil -->
  <div id="mobile-menu" class="hidden border-t border-surface-200 bg-white md:hidden" data-mobile-menu>
    <ul class="space-y-1 px-4 py-3" role="list">
      {navigation.map((item) => (
        <li>
          <a
            href={item.href}
            data-nav-link-mobile={item.sectionId}
            class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-text-secondary hover:bg-primary-50 hover:text-primary-600"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={navIcons[item.sectionId]} />
            </svg>
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://github.com/686f6c61/PSPO-Agent"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium text-text-secondary hover:bg-primary-50 hover:text-primary-600"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          GitHub
        </a>
      </li>
    </ul>
  </div>
</header>

<!-- Modal de changelog -->
<div data-changelog-modal class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/50 backdrop-blur-sm p-4" role="dialog" aria-modal="true" aria-label="Historial de cambios">
  <div class="relative w-full max-w-lg max-h-[80vh] overflow-y-auto rounded-xl bg-white shadow-2xl border border-surface-200 [scrollbar-width:none] [-webkit-overflow-scrolling:touch] [&::-webkit-scrollbar]:hidden">
    <!-- Header del modal -->
    <div class="sticky top-0 z-10 flex items-center justify-between border-b border-surface-200 bg-white px-6 py-4 rounded-t-xl">
      <div class="flex items-center gap-2">
        <svg class="h-5 w-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
        </svg>
        <h2 class="text-lg font-bold text-text-primary">Historial de cambios</h2>
      </div>
      <button data-changelog-close class="rounded-md p-1.5 text-text-muted hover:text-text-primary hover:bg-surface-100 transition-colors" aria-label="Cerrar">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <!-- Contenido del changelog -->
    <div class="px-6 py-4 space-y-6">
      {changelog.map((release, idx) => (
        <div class:list={[idx > 0 && 'border-t border-surface-100 pt-6']}>
          <div class="flex items-center gap-2 mb-3">
            <span class:list={[
              'inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-bold',
              idx === 0 ? 'bg-primary-100 text-primary-800' : 'bg-surface-100 text-text-secondary'
            ]}>
              {release.version}
            </span>
            <span class="text-xs text-text-muted">{release.date}</span>
            {idx === 0 && <span class="text-xs font-medium text-primary-600">Actual</span>}
          </div>
          {release.sections.map((section) => (
            <div class="mb-3">
              <div class="flex items-center gap-1.5 mb-1.5">
                <svg class="h-4 w-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d={section.icon} />
                </svg>
                <h4 class="text-sm font-semibold text-text-primary">{section.title}</h4>
              </div>
              <ul class="space-y-1 pl-6">
                {section.items.map((item) => (
                  <li class="text-xs text-text-secondary leading-relaxed list-disc">{item}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      ))}
    </div>

    <!-- Footer del modal -->
    <div class="sticky bottom-0 border-t border-surface-200 bg-white px-6 py-3 rounded-b-xl">
      <a
        href="https://github.com/686f6c61/PSPO-Agent/blob/main/CHANGELOG.md"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-xs font-medium text-primary-600 hover:text-primary-700 transition-colors"
      >
        Ver changelog completo en GitHub
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
      </a>
    </div>
  </div>
</div>

<script>
  import '../../scripts/header-nav';

  // Changelog modal
  function initChangelog() {
    const modal = document.querySelector('[data-changelog-modal]') as HTMLElement;
    if (!modal) return;

    const toggleBtns = document.querySelectorAll('[data-changelog-toggle]');
    const closeBtn = modal.querySelector('[data-changelog-close]');

    function open() {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    toggleBtns.forEach(btn => btn.addEventListener('click', open));
    closeBtn?.addEventListener('click', close);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });
  }

  // Funciona tanto con View Transitions como sin ellas
  initChangelog();
  document.addEventListener('astro:page-load', initChangelog);
</script>
