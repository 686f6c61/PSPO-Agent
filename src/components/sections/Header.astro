---
/**
 * Header sticky con navegacion principal.
 *
 * Muestra el logo, enlaces de seccion, badge de version con changelog modal,
 * y enlace a GitHub. En movil colapsa en un menu hamburguesa.
 * El enlace activo se resalta mediante scroll spy implementado en
 * src/scripts/header-nav.ts. Los items de navegacion vienen de
 * src/data/navigation.ts.
 */
import { navigation } from '../../data/navigation';

const navIcons: Record<string, string> = {
