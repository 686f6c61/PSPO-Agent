---
/**
 * Seccion de instalacion del plugin.
 *
 * Organiza las instrucciones de instalacion en tres pestanas (Linux, macOS,
 * Windows) usando TabGroup. La pestana activa por defecto se detecta por
 * User-Agent en el script de tab-group.ts. Ademas incluye los pasos de
 * configuracion de Trello y un acordeon de resolucion de problemas.
 *
 * Todos los datos vienen de src/data/installation.ts.
 */
import SectionHeading from '../ui/SectionHeading.astro';
import TabGroup from '../ui/TabGroup.astro';
import CodeBlock from '../ui/CodeBlock.astro';
import { installations, troubleshooting, trelloSetupSteps } from '../../data/installation';

const tabs = installations.map((inst) => ({
  id: inst.os,
  label: inst.label,
}));

const groupId = 'os-install';
---

<section id="instalacion" class="py-8 sm:py-12 bg-surface-50">
  <div class="mx-auto max-w-4xl px-4 sm:px-6">
    <SectionHeading
      id="instalacion-heading"
      title="Instalación"
      subtitle="Instala el plugin en menos de 5 minutos. Sin conocimientos previos de APIs."
    />

    <TabGroup tabs={tabs} groupId={groupId} ariaLabel="Seleccionar sistema operativo">
      {installations.map((inst) => (
        <div
          id={`panel-${groupId}-${inst.os}`}
          role="tabpanel"
          aria-labelledby={`tab-${groupId}-${inst.os}`}
          data-tab-panel={inst.os}
          hidden={inst.os !== 'linux'}
        >
          <div class="space-y-6">
            {inst.steps.map((step, index) => (
              <div class="rounded-lg border border-surface-200 bg-white p-5">
                <div class="flex items-start gap-3">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary-100 text-xs font-bold text-primary-700">
                    {index + 1}
                  </span>
                  <div class="flex-1">
                    <h4 class="font-semibold text-text-primary">{step.title}</h4>
                    <p class="mt-1 text-sm text-text-secondary">{step.description}</p>
                    {step.code && (
                      <div class="mt-3">
                        <CodeBlock code={step.code} language={step.language} />
                      </div>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </TabGroup>

    <!-- Configuracion de Trello -->
    <div class="mt-12">
      <h3 class="text-xl font-semibold text-text-primary mb-6">Configuración de Trello</h3>
      <p class="text-text-secondary mb-6">
        El plugin guía la configuración de Trello automáticamente en la primera ejecución.
        No necesitas editar ficheros manualmente. El asistente te lleva paso a paso:
      </p>
      <div class="space-y-4">
        {trelloSetupSteps.map((step) => (
          <div class="flex items-start gap-3 rounded-lg border border-surface-200 bg-white p-4">
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary-100 text-xs font-bold text-primary-700">
              {step.step}
            </span>
            <div>
              <h4 class="font-semibold text-text-primary">{step.title}</h4>
              <p class="mt-1 text-sm text-text-secondary">{step.description}</p>
              {step.link && (
                <a
                  href={step.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-1 inline-flex items-center text-sm text-primary-600 hover:text-primary-700"
                >
                  {step.link}
                  <svg class="ml-1 h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5zm7.5-3a.75.75 0 01.75-.75h4.5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0V4.06l-5.22 5.22a.75.75 0 11-1.06-1.06l5.22-5.22h-2.69a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
