---
/**
 * Seccion de arquitectura del plugin PSPO Agent.
 *
 * Contiene: vision general del plugin, metricas clave del runtime real,
 * diagrama de componentes en
 * HTML/CSS, diagrama de flujo de datos, tabla de herramientas MCP,
 * referencia de configuracion (settings.json) y plantilla de variables
 * de entorno (.env).
 *
 * Los datos de herramientas MCP y configuracion estan definidos inline porque
 * son especificos de esta seccion y no se reutilizan en otros componentes.
 */
import SectionHeading from '../ui/SectionHeading.astro';
import CodeBlock from '../ui/CodeBlock.astro';
import { pluginMeta } from '../../data/plugin';

const mcpTools = [
  { tool: 'verify-credentials', method: 'GET', endpoint: '/1/members/me', input: 'key, token', output: 'Nombre usuario, id, URL perfil' },
  { tool: 'list-boards', method: 'GET', endpoint: '/1/members/me/boards', input: 'key, token', output: 'Lista de tableros (id, nombre, URL)' },
  { tool: 'get-board', method: 'GET', endpoint: '/1/boards/{id}', input: 'boardId', output: 'Tablero con listas y etiquetas' },
  { tool: 'create-board', method: 'POST', endpoint: '/1/boards', input: 'name, defaultLists', output: 'Tablero creado (id, URL)' },
  { tool: 'manage-lists', method: 'POST/PUT', endpoint: '/1/boards/{id}/lists', input: 'boardId, action, params', output: 'Lista creada/modificada' },
  { tool: 'manage-labels', method: 'POST/PUT', endpoint: '/1/boards/{id}/labels', input: 'boardId, action, params', output: 'Etiqueta creada/modificada' },
  { tool: 'create-cards', method: 'POST', endpoint: '/1/cards', input: 'listId, cards[]', output: 'Tarjetas creadas (id, URL)' },
  { tool: 'search-cards', method: 'GET', endpoint: '/1/boards/{id}/cards', input: 'boardId, query', output: 'Tarjetas que coinciden' },
  { tool: 'get-card', method: 'GET', endpoint: '/1/cards/{id}', input: 'cardId', output: 'Tarjeta completa con miembros, labels y checklists' },
  { tool: 'update-card', method: 'PUT', endpoint: '/1/cards/{id}', input: 'cardId, params', output: 'Tarjeta sincronizada' },
  { tool: 'add-checklist', method: 'POST', endpoint: '/1/cards/{id}/checklists', input: 'cardId, name, items[]', output: 'Checklist creado con items' },
  { tool: 'attach-file', method: 'POST', endpoint: '/1/cards/{id}/attachments', input: 'cardId, fileName, content', output: 'Adjunto creado (id, URL)' },
  { tool: 'get-board-members', method: 'GET', endpoint: '/1/boards/{id}/members', input: 'boardId', output: 'Miembros con ID, nombre y username' },
  { tool: 'invite-member', method: 'PUT', endpoint: '/1/boards/{id}/members', input: 'boardId, email, fullName', output: 'Invitación enviada' },
];

const configSections = [
  {
    key: 'trello',
    title: 'Configuración de Trello',
    items: [
      { param: 'default_lists', description: 'Columnas por defecto: Backlog, Sprint activo, Bloqueada, En progreso, En revision, Hecho' },
      { param: 'default_labels', description: 'Etiquetas de prioridad: Critica (rojo), Alta (naranja), Media (amarillo), Baja (azul)' },
      { param: 'publish_target_list', description: 'Lista destino para publicar historias (por defecto: Backlog)' },
      { param: 'card_position', description: 'Posición de las tarjetas nuevas (bottom)' },
    ],
  },
  {
    key: 'discovery',
    title: 'Configuración de descubrimiento',
    items: [
      { param: 'min_questions', description: 'Mínimo de preguntas de descubrimiento: 3' },
      { param: 'max_questions', description: 'Máximo de preguntas de descubrimiento: 8' },
      { param: 'require_confirmation_before_generation', description: 'Requiere confirmación del alcance antes de generar historias' },
    ],
  },
  {
    key: 'stories',
    title: 'Configuración de historias',
    items: [
      { param: 'format', description: 'Formato: "Como [rol], quiero [acción], para [beneficio]"' },
      { param: 'require_given_when_then', description: 'Requiere criterios en formato Given/When/Then' },
      { param: 'min_positive_scenarios', description: 'Mínimo de escenarios positivos por historia: 1' },
      { param: 'min_negative_scenarios', description: 'Mínimo de escenarios negativos por historia: 1' },
      { param: 'estimation_unit', description: 'Unidad de estimación: horas efectivas con agentes (XS=1, S=2, M=4, L=8, XL=16)' },
    ],
  },
  {
    key: 'sprint',
    title: 'Configuración de sprint',
    items: [
      { param: 'duration_days', description: 'Duración por defecto del sprint: 5 días máximo' },
      { param: 'focus_hours_per_day', description: 'Horas reales de foco por persona y día: 6' },
      { param: 'ai_agent_factor', description: 'Factor base para miembros que usan agentes IA: 0.65' },
      { param: 'ai_agent_factor_range', description: 'Rango configurable recomendado: 0.30 - 0.80' },
    ],
  },
  {
    key: 'autopilot',
    title: 'Configuración de autopilot',
    items: [
      { param: 'default_input_dir', description: 'Carpeta de entrada por defecto: .pspo-agent/inbox' },
      { param: 'accepted_brief_files', description: 'Acepta brief.md, instrucciones.md, prd.md, requirements.md y brief.txt' },
      { param: 'require_final_gate', description: 'Siempre deja una compuerta final antes de publicar' },
      { param: 'stop_after_audit_if_trello_missing', description: 'Se detiene tras la auditoría si Trello no está configurado' },
    ],
  },
  {
    key: 'publish',
    title: 'Configuración de publicación',
    items: [
      { param: 'save_local_before_trello', description: 'Siempre guarda localmente antes de publicar en Trello' },
      { param: 'check_duplicates_by_title', description: 'Verifica duplicados por título antes de crear tarjetas' },
      { param: 'require_confirmation', description: 'Requiere confirmación del usuario antes de publicar' },
      { param: 'require_member_assignment_for_assigned_stories', description: 'No da por cerrada una tarjeta asignada si no se resuelve el memberId real' },
    ],
  },
];

const envTemplate = `# Credenciales de la API de Trello
TRELLO_API_KEY=          # API Key del Power-Up (32 caracteres hex)
TRELLO_TOKEN=            # Token de autorización (cadena ATTA...)
TRELLO_TOKEN_CREATED=    # Fecha de creación del token (YYYY-MM-DD, gestionada por el plugin)
TRELLO_BOARD_ID=         # ID del tablero seleccionado`;
---

<section id="arquitectura" class="py-8 sm:py-12 bg-transparent">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeading
      id="arquitectura-heading"
      title="Arquitectura"
      subtitle={`${pluginMeta.counts.commands} comandos, ${pluginMeta.counts.skills} skills, ${pluginMeta.counts.agents} agentes, ${pluginMeta.counts.mcpTools} herramientas MCP y ${pluginMeta.counts.hookGuards} guardrails de runtime para Trello y autopilot.`}
    />

    <!-- Vision general -->
    <div class="mb-12 max-w-3xl mx-auto">
      <p class="text-text-secondary leading-relaxed">
        PSPO Agent es un plugin no oficial de Claude Code que opera como un conjunto coordinado de
        <strong>skills</strong> (instrucciones estructuradas en Markdown) que guian el comportamiento del LLM,
        combinado con <strong>hooks</strong>, un <strong>launcher MCP</strong> y un
        <strong> fallback oficial</strong> para Trello. La lógica de producto se reparte entre
        Markdown, runtime y utilidades Python ligeras: onboarding, generación, auditoría,
        asignación, dependencias, sprint y sincronización con Trello sin depender de un backend externo.
      </p>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <span class="rounded-full bg-primary-50 px-3 py-1 text-xs font-medium text-primary-700">
          Documents/ es la documentación viva del plugin
        </span>
        <a
          href={pluginMeta.docsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700"
        >
          Abrir documentación técnica
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5zm7.5-3a.75.75 0 01.75-.75h4.5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0V4.06l-5.22 5.22a.75.75 0 11-1.06-1.06l5.22-5.22h-2.69a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Componentes clave -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4 mb-12">
      <div class="rounded-xl bg-gradient-to-br from-primary-500 to-primary-700 p-5 text-center shadow-lg shadow-primary-500/20">
        <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-lg bg-white/20">
          <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
        </div>
        <div class="text-3xl font-bold text-white">{pluginMeta.counts.skills}</div>
        <div class="text-sm text-primary-100 mt-1">Skills especializadas</div>
      </div>
      <div class="rounded-xl bg-gradient-to-br from-primary-500 to-primary-700 p-5 text-center shadow-lg shadow-primary-500/20">
        <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-lg bg-white/20">
          <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
        </div>
        <div class="text-3xl font-bold text-white">{pluginMeta.counts.agents}</div>
        <div class="text-sm text-primary-100 mt-1">Agentes especializados</div>
      </div>
      <div class="rounded-xl bg-gradient-to-br from-primary-500 to-primary-700 p-5 text-center shadow-lg shadow-primary-500/20">
        <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-lg bg-white/20">
          <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-3.06a1.5 1.5 0 010-2.58l5.1-3.06a1.5 1.5 0 011.639.058l4.928 3.674a1.5 1.5 0 010 2.416l-4.928 3.674a1.5 1.5 0 01-1.64.058z" /></svg>
        </div>
        <div class="text-3xl font-bold text-white">{pluginMeta.counts.mcpTools}</div>
        <div class="text-sm text-primary-100 mt-1">Herramientas MCP</div>
      </div>
      <div class="rounded-xl bg-gradient-to-br from-primary-500 to-primary-700 p-5 text-center shadow-lg shadow-primary-500/20">
        <div class="mx-auto mb-2 flex h-10 w-10 items-center justify-center rounded-lg bg-white/20">
          <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
        </div>
        <div class="text-3xl font-bold text-white">{pluginMeta.counts.hookGuards}</div>
        <div class="text-sm text-primary-100 mt-1">Guardrails de runtime</div>
      </div>
    </div>

    <!-- Diagrama de arquitectura -->
    <div class="mb-12">
      <h3 class="text-xl font-semibold text-text-primary mb-4">Diagrama de componentes</h3>
      <figure class="overflow-x-auto rounded-lg border border-surface-200 bg-white p-6" aria-label="Diagrama de arquitectura del plugin PSPO Agent">
        <div class="min-w-[640px] space-y-6">
          <!-- Capa: Usuario -->
          <div class="flex justify-center">
            <div class="flex items-center gap-2 rounded-lg bg-surface-100 px-6 py-3 text-sm font-semibold text-text-primary border border-surface-300">
              <svg class="h-5 w-5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" /></svg>
              Usuario (terminal)
            </div>
          </div>
          <div class="flex justify-center" aria-hidden="true">
            <svg class="h-8 w-6 text-primary-300" viewBox="0 0 24 32" fill="none"><path d="M12 0v24M7 19l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </div>

          <!-- Capa: Claude Code -->
          <div class="flex justify-center">
            <div class="flex items-center gap-2 rounded-lg bg-primary-50 border-2 border-primary-300 px-6 py-3 text-sm font-semibold text-primary-800">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
              Claude Code (LLM + CLI)
            </div>
          </div>
          <div class="flex justify-center" aria-hidden="true">
            <svg class="h-8 w-6 text-primary-300" viewBox="0 0 24 32" fill="none"><path d="M12 0v24M7 19l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </div>

          <!-- Capa: Plugin PSPO Agent -->
          <div class="rounded-xl border-2 border-dashed border-primary-300 bg-primary-50/30 p-5">
            <div class="text-center text-xs font-bold uppercase tracking-wide text-primary-600 mb-4">Plugin PSPO Agent</div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              <!-- Skills -->
              <div class="rounded-lg border border-surface-200 bg-white p-3">
                <div class="flex items-center gap-1.5 text-xs font-bold text-primary-700 mb-2">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
                  Skills ({pluginMeta.counts.skills})
                </div>
                <ul class="grid grid-cols-2 gap-x-3 gap-y-1 text-xs text-text-secondary">
                  {pluginMeta.skillNames.map((skillName) => (
                    <li>{skillName}</li>
                  ))}
                </ul>
              </div>
              <!-- Agentes -->
              <div class="rounded-lg border border-surface-200 bg-white p-3">
                <div class="flex items-center gap-1.5 text-xs font-bold text-primary-700 mb-2">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
                  Agentes (6)
                </div>
                <ul class="space-y-1 text-xs text-text-secondary">
                  <li class="flex items-center gap-1"><span class="inline-block h-2 w-2 rounded-full bg-cyan-400"></span> requirement-analyst</li>
                  <li class="flex items-center gap-1"><span class="inline-block h-2 w-2 rounded-full bg-blue-500"></span> product-owner</li>
                  <li class="flex items-center gap-1"><span class="inline-block h-2 w-2 rounded-full bg-green-500"></span> publisher</li>
                  <li class="flex items-center gap-1"><span class="inline-block h-2 w-2 rounded-full bg-amber-500"></span> sprint-planner</li>
                  <li class="flex items-center gap-1"><span class="inline-block h-2 w-2 rounded-full bg-fuchsia-500"></span> culture-guardian</li>
                  <li class="flex items-center gap-1"><span class="inline-block h-2 w-2 rounded-full bg-red-500"></span> senior-auditor</li>
                </ul>
              </div>
              <!-- Hooks -->
              <div class="rounded-lg border border-surface-200 bg-white p-3">
                <div class="flex items-center gap-1.5 text-xs font-bold text-primary-700 mb-2">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
                  Guardrails clave
                </div>
                <ul class="space-y-1.5 text-xs text-text-secondary">
                  <li class="flex items-start gap-1.5">
                    <svg class="h-3.5 w-3.5 mt-0.5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
                    Validar entorno y credenciales antes de cada llamada MCP o fallback
                  </li>
                  <li class="flex items-start gap-1.5">
                    <svg class="h-3.5 w-3.5 mt-0.5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
                    Bloquear acceso directo a Trello via Bash y Fetch
                  </li>
                  <li class="flex items-start gap-1.5">
                    <svg class="h-3.5 w-3.5 mt-0.5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
                    Bloquear deriva en autopilot con Read, Glob, ToolSearch y TodoWrite
                  </li>
                  <li class="flex items-start gap-1.5">
                    <svg class="h-3.5 w-3.5 mt-0.5 text-amber-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>
                    Frenar fugas de secretos y re-preguntas de credenciales
                  </li>
                  <li class="flex items-start gap-1.5">
                    <svg class="h-3.5 w-3.5 mt-0.5 text-amber-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m6 2.25a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                    Persistir skill activa, gates y verificar .gitignore al escribir
                  </li>
                </ul>
              </div>
              <!-- MCP Server -->
              <div class="rounded-lg border-2 border-primary-200 bg-primary-50 p-3">
                <div class="flex items-center gap-1.5 text-xs font-bold text-primary-700 mb-2">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z" /></svg>
                  Servidor MCP
                </div>
                <div class="space-y-1">
                  <div class="flex items-center gap-1.5 text-xs text-text-secondary">
