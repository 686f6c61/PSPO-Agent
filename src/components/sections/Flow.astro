---
/**
 * Seccion del flujo de trabajo del plugin.
 *
 * Visualiza los 5 pasos del flujo (Instalar > Descubrir > Generar >
 * Validar > Publicar) con dos layouts: horizontal en escritorio (grid de 5
 * columnas con flechas SVG entre pasos) y vertical en movil (timeline con
 * linea vertical). Los datos de cada paso estan definidos inline.
 */
import SectionHeading from '../ui/SectionHeading.astro';
import FlowStep from '../ui/FlowStep.astro';

const steps = [
  { step: 1, title: 'Instalar', description: 'Un comando en la terminal y listo', icon: 'M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3' },
  { step: 2, title: 'Analizar', description: 'Pega tu documento y el agente pregunta hasta entenderlo', icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9zm3.75 11.625a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z' },
  { step: 3, title: 'Generar', description: 'Historias de usuario con criterios Given/When/Then', icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z' },
  { step: 4, title: 'Validar', description: 'Apruebas, rechazas o pides cambios historia por historia', icon: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  { step: 5, title: 'Publicar', description: 'Tarjetas en Trello con adjunto MD, checklist DoD y miembros', icon: 'M3 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 010 1.954l-7.108 4.061A1.125 1.125 0 013 16.811V8.69zM12.75 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 010 1.954l-7.108 4.061a1.125 1.125 0 01-1.683-.977V8.69z' },
];
---

<section id="flujo" class="py-8 sm:py-12 bg-gradient-to-b from-white to-primary-50/30">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeading
      id="flujo-heading"
      title="Flujo de trabajo"
      subtitle="De la idea al tablero de Trello en 5 pasos. Sin trabajo manual."
    />

    <!-- Flujo en desktop: horizontal -->
    <div class="hidden lg:grid lg:grid-cols-5 lg:gap-0 lg:items-start">
      {steps.map((step, index) => (
        <FlowStep
          step={step.step}
          title={step.title}
          description={step.description}
          icon={step.icon}
          isLast={index === steps.length - 1}
        />
      ))}
    </div>

    <!-- Flujo en movil: vertical -->
    <div class="lg:hidden">
      <div class="relative pl-10">
        <div class="absolute left-[1.0625rem] top-0 bottom-0 w-0.5 bg-primary-200" aria-hidden="true"></div>
        {steps.map((step, index) => (
          <div class={`relative flex items-start gap-4 ${index > 0 ? 'mt-8' : ''}`}>
            <div class="relative z-10 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary-500 text-white shadow-sm">
              {step.icon ? (
                <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
                </svg>
              ) : (
                <span class="font-bold text-sm">{step.step}</span>
              )}
            </div>
            <div class="pt-0.5">
              <h3 class="text-base font-semibold text-text-primary">{step.title}</h3>
              <p class="mt-1 text-sm text-text-secondary">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
