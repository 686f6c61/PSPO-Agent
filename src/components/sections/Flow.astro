---
/**
 * Seccion del flujo de trabajo del plugin.
 *
 * Visualiza los 6 pasos del flujo (Instalar > Entender > Generar >
 * Alinear equipo > Planificar > Publicar) con dos layouts: horizontal en escritorio (grid de 6
 * columnas con flechas SVG entre pasos) y vertical en movil (timeline con
 * linea vertical). Los datos de cada paso estan definidos inline.
 */
import SectionHeading from '../ui/SectionHeading.astro';
import FlowStep from '../ui/FlowStep.astro';

const steps = [
  { step: 1, title: 'Instalar', description: 'Un comando en la terminal y listo', icon: 'M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3' },
  { step: 2, title: 'Entender', description: 'Analyze o discovery según el contexto que traigas', icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9zm3.75 11.625a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z' },
  { step: 3, title: 'Generar', description: 'Historias de usuario con criterios Given/When/Then', icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z' },
  { step: 4, title: 'Alinear equipo', description: 'Equipo, ownership y dependencias antes del sprint', icon: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z' },
  { step: 5, title: 'Planificar', description: 'Sprint activo de hasta 5 días con horas efectivas reales', icon: 'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75' },
  { step: 6, title: 'Publicar', description: 'Trello o Notion con resumen, adjunto .md, dependencias y responsables', icon: 'M3 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 010 1.954l-7.108 4.061A1.125 1.125 0 013 16.811V8.69zM12.75 8.689c0-.864.933-1.406 1.683-.977l7.108 4.061a1.125 1.125 0 010 1.954l-7.108 4.061a1.125 1.125 0 01-1.683-.977V8.69z' },
];
---

<section id="flujo" class="py-8 sm:py-12 bg-transparent">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <SectionHeading
      id="flujo-heading"
      title="Flujo de trabajo"
      subtitle="De la idea al sprint activo en 6 pasos. El sistema avanza solo y se detiene cuando tu decisión cambia el resultado."
    />

    <!-- Flujo en desktop: horizontal -->
    <div class="hidden lg:grid lg:grid-cols-6 lg:gap-0 lg:items-start">
      {steps.map((step, index) => (
        <FlowStep
          step={step.step}
          title={step.title}
          description={step.description}
          icon={step.icon}
          isLast={index === steps.length - 1}
        />
      ))}
    </div>

    <!-- Flujo en movil: vertical -->
    <div class="lg:hidden">
      <div class="relative pl-10">
        <div class="absolute left-[1.0625rem] top-0 bottom-0 w-0.5 bg-primary-200" aria-hidden="true"></div>
        {steps.map((step, index) => (
          <div class={`relative flex items-start gap-4 ${index > 0 ? 'mt-8' : ''}`}>
            <div class="relative z-10 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-primary-200/70 bg-primary-500 text-white">
              {step.icon ? (
                <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
                </svg>
              ) : (
                <span class="font-bold text-sm">{step.step}</span>
              )}
            </div>
            <div class="pt-0.5">
              <h3 class="text-base font-semibold text-text-primary">{step.title}</h3>
              <p class="mt-1 text-sm text-text-secondary">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
