---
/**
 * Seccion hero: primera pantalla de la onepage.
 *
 * Muestra la propuesta de valor del plugin, dos CTAs (instalar y ver
 * funcionalidades) y las tarjetas de publico objetivo. Todo el
 * contenido es estatico.
 */
import { site } from '../../data/site';
import IntegrationShowcase from '../ui/IntegrationShowcase.astro';
---

<section id="hero" class="relative overflow-hidden bg-transparent pt-24 pb-16 sm:pt-32 sm:pb-24">
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mb-6 flex justify-end lg:absolute lg:-top-6 lg:-right-6 lg:z-20 lg:mb-0 lg:w-full lg:max-w-xs xl:-right-12">
      <div
        id="alpha-notice"
        class="relative w-full max-w-sm overflow-hidden rounded-2xl border border-primary-200/80 bg-white/92 p-4 text-left shadow-[0_24px_64px_rgba(59,108,219,0.18)] ring-1 ring-primary-100/80 backdrop-blur-md"
      >
        <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(135deg,_rgba(239,246,255,0.96),_rgba(255,255,255,0.92)_45%,_rgba(236,253,245,0.72))]"></div>
        <div class="relative flex items-start gap-3">
          <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-primary-100 text-primary-700 shadow-inner shadow-white/70">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.75h4.5m-4.5 0v4.172a3 3 0 0 1-.879 2.121L6.75 12.164a3 3 0 0 0-.879 2.122V15a5.25 5.25 0 0 0 5.25 5.25h1.758A5.25 5.25 0 0 0 18.129 15v-.714a3 3 0 0 0-.879-2.122l-2.121-2.121a3 3 0 0 1-.879-2.121V3.75m-4.5 0h4.5" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 14.25h6" />
            </svg>
          </span>
          <div class="min-w-0 flex-1 pr-2">
            <div class="flex items-center gap-2">
              <span class="rounded-full bg-primary-600 px-2.5 py-1 font-mono text-[11px] font-bold tracking-[0.22em] text-white">
                ALPHA
              </span>
              <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-primary-700">
                Early access
              </span>
            </div>
            <p class="mt-2 text-sm font-semibold leading-snug text-text-primary">
              Estamos afinando el producto con feedback.
            </p>
            <div class="mt-3 flex items-center justify-center gap-2">
              <a
                href={`${site.repository}/issues`}
                target="_blank"
                rel="noopener noreferrer"
                title="Abrir GitHub Issues"
                aria-label="Abrir GitHub Issues"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-primary-200 bg-white/85 text-primary-700 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary-300 hover:bg-white hover:text-primary-800 hover:shadow-md"
              >
                <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 0a12 12 0 0 0-3.793 23.385c.6.111.82-.261.82-.577v-2.234c-3.338.726-4.042-1.416-4.042-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.082-.729.082-.729 1.206.084 1.84 1.238 1.84 1.238 1.071 1.834 2.809 1.304 3.495.997.108-.775.42-1.305.763-1.604-2.665-.304-5.467-1.334-5.467-5.93 0-1.311.469-2.382 1.237-3.222-.125-.303-.536-1.524.117-3.176 0 0 1.008-.322 3.3 1.23A11.49 11.49 0 0 1 12 5.8c1.02.005 2.047.138 3.005.404 2.292-1.552 3.3-1.23 3.3-1.23.654 1.653.243 2.874.119 3.176.77.84 1.237 1.911 1.237 3.222 0 4.608-2.806 5.624-5.478 5.92.431.372.815 1.103.815 2.222v3.293c0 .319.218.693.825.576A12.002 12.002 0 0 0 12 0Z" />
                </svg>
              </a>
              <a
                href="https://x.com/hex686f6c61"
                target="_blank"
                rel="noopener noreferrer"
                title="Abrir perfil de X de @hex686f6c61"
                aria-label="Abrir perfil de X de @hex686f6c61"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-primary-200 bg-white/85 text-primary-700 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary-300 hover:bg-white hover:text-primary-800 hover:shadow-md"
              >
                <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18.901 1.153h3.68l-8.038 9.188L24 22.847h-7.406l-5.8-7.584-6.64 7.584H.473l8.596-9.825L0 1.154h7.594l5.243 6.932 6.064-6.933Zm-1.292 19.49h2.039L6.486 3.25H4.298l13.311 17.394Z" />
                </svg>
              </a>
            </div>
          </div>
          <button
            id="alpha-notice-close"
            type="button"
            class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-primary-200/80 bg-white/70 text-text-muted transition-colors hover:border-primary-300 hover:text-text-primary"
            aria-label="Cerrar aviso de early access"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6 6 18" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="text-center">
      <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-primary-200/60 bg-white/80 px-5 py-2.5 shadow-sm backdrop-blur-sm">
        <svg class="h-5 w-5 text-primary-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3" />
        </svg>
        <span class="text-sm font-medium text-text-secondary">Plugin para</span>
        <span class="rounded-md bg-gray-900 px-2.5 py-1 font-mono text-xs font-semibold text-white tracking-wide">Claude Code</span>
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight text-text-primary sm:text-5xl lg:text-6xl">
        PSPO Agent
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-text-secondary leading-relaxed sm:text-xl">
        Plugin de Claude Code que actúa como
        <strong class="text-primary-600">Product Owner profesional</strong>.
        Descubrimiento de producto, historias de usuario, asignación operativa,
        dependencias, sprint con agentes y publicación en Trello o Notion.
        Para desarrolladores, tech leads y equipos medianos que quieren construir producto, no coordinarlo a mano.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="#instalacion"
          class="inline-flex items-center rounded-lg bg-primary-600 px-6 py-3 text-base font-semibold text-white shadow-sm transition-colors hover:bg-primary-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
        >
          Instalar ahora
          <svg class="ml-2 h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M2 10a.75.75 0 01.75-.75h12.59l-2.1-1.95a.75.75 0 111.02-1.1l3.5 3.25a.75.75 0 010 1.1l-3.5 3.25a.75.75 0 11-1.02-1.1l2.1-1.95H2.75A.75.75 0 012 10z" clip-rule="evenodd" />
          </svg>
        </a>
        <a
          href="#funcionalidades"
          class="inline-flex items-center rounded-lg border border-surface-300 bg-white px-6 py-3 text-base font-semibold text-text-primary shadow-sm transition-colors hover:bg-surface-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
        >
          Ver funcionalidades
        </a>
      </div>

      <div class="mx-auto mt-8 max-w-4xl">
        <IntegrationShowcase compact={true} />
      </div>
    </div>

    <!-- Para quien es -->
    <div class="mx-auto mt-16 grid max-w-5xl gap-6 lg:grid-cols-3">
      <div class="rounded-xl border border-surface-200 bg-white p-6 shadow-md hover:shadow-lg transition-shadow">
        <div class="flex items-center gap-3 mb-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-primary-500 to-primary-600 shadow-sm">
            <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
            </svg>
          </div>
          <h3 class="font-semibold text-text-primary">Desarrollador independiente</h3>
        </div>
        <p class="text-sm text-text-secondary leading-relaxed">
          Tienes ideas de producto pero no sabes traducirlas en historias accionables.
          PSPO Agent te hace las preguntas correctas y genera la documentación de producto que no tienes tiempo de hacer.
        </p>
      </div>
      <div class="rounded-xl border border-surface-200 bg-white p-6 shadow-md hover:shadow-lg transition-shadow">
        <div class="flex items-center gap-3 mb-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-primary-500 to-primary-600 shadow-sm">
            <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-text-primary">Tech lead de equipo pequeño</h3>
        </div>
        <p class="text-sm text-text-secondary leading-relaxed">
          Haces de PO a tiempo parcial además de tu trabajo técnico.
          PSPO Agent estandariza la calidad de las historias, distribuye el trabajo y detecta dependencias entre tareas.
        </p>
      </div>
      <div class="rounded-xl border border-surface-200 bg-white p-6 shadow-md hover:shadow-lg transition-shadow">
        <div class="flex items-center gap-3 mb-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-primary-500 to-primary-600 shadow-sm">
            <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6h16.5M6 3.75v4.5m12-4.5v4.5M4.5 9.75h15a.75.75 0 01.75.75v7.5a2.25 2.25 0 01-2.25 2.25h-12A2.25 2.25 0 013.75 18v-7.5a.75.75 0 01.75-.75zm3.75 3h3m-3 3h6" />
            </svg>
          </div>
          <h3 class="font-semibold text-text-primary">Equipo mediano con varias manos</h3>
        </div>
        <p class="text-sm text-text-secondary leading-relaxed">
          Ya no te falla definir historias, te falla coordinarlas bien entre backend, frontend, QA y negocio.
          PSPO Agent convierte un brief en backlog operativo, reparte ownership, visibiliza bloqueos y deja Trello o Notion listos para ejecutar.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const initAlphaNotice = () => {
    const notice = document.getElementById('alpha-notice');
    const closeBtn = document.getElementById('alpha-notice-close');

    if (!notice || !closeBtn) return;
    notice.style.display = '';

    closeBtn.onclick = () => {
      notice.style.display = 'none';
    };
  };

  initAlphaNotice();
  document.addEventListener('astro:page-load', initAlphaNotice);
</script>
