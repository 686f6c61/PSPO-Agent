---
/**
 * Footer de la web.
 *
 * Muestra descripcion del proyecto, enlaces al repositorio y licencia,
 * y accesos directos a las secciones de la onepage. Los metadatos del
 * proyecto (nombre, repositorio, autor, licencia) vienen de src/data/site.ts.
 */
import { site } from '../../data/site';

const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-900 py-12">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Sobre el proyecto -->
      <div class="sm:col-span-2">
        <div class="flex items-center gap-2">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary-500 p-1">
            <svg class="h-6 w-6" viewBox="0 0 512 512" fill="none" aria-hidden="true">
              <g transform="translate(56, 56) scale(0.78)" stroke="white" fill="none" stroke-width="28" stroke-linecap="round" stroke-linejoin="round">
                <rect x="30" y="60" width="280" height="360" rx="30" />
                <path d="M130 60V40a40 40 0 0 1 80 0v20" />
                <rect x="120" y="20" width="100" height="50" rx="12" />
                <line x1="90" y1="160" x2="260" y2="160" stroke-width="22" />
                <line x1="90" y1="210" x2="260" y2="210" stroke-width="22" />
                <line x1="90" y1="260" x2="220" y2="260" stroke-width="22" />
                <circle cx="240" cy="360" r="55" fill="#3B6CDB" />
                <path d="M215 360l18 18 35-35" stroke-width="22" />
                <path d="M340 200h60v200h60" />
                <path d="M400 280h60" />
                <rect x="450" y="180" width="40" height="40" rx="6" stroke-width="20" />
                <rect x="450" y="260" width="40" height="40" rx="6" stroke-width="20" />
                <rect x="450" y="380" width="40" height="40" rx="6" stroke-width="20" />
              </g>
            </svg>
          </div>
          <span class="text-lg font-bold text-white">{site.name}</span>
        </div>
        <p class="mt-3 max-w-md text-sm text-primary-200 leading-relaxed">
          Plugin no oficial y open source para descubrimiento de producto,
          historias de usuario, dependencias, sprint con agentes y publicación
          operativa en Trello, Notion y futuros proveedores.
        </p>
      </div>

      <!-- Enlaces -->
      <div>
        <h3 class="text-sm font-semibold text-primary-300 uppercase tracking-wide">Proyecto</h3>
        <ul class="mt-3 space-y-2" role="list">
          <li>
            <a
              href={site.repository}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-primary-200 hover:text-white transition-colors"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              Repositorio en GitHub
            </a>
          </li>
          <li>
            <a
              href={`${site.repository}/blob/main/LICENSE`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-primary-200 hover:text-white transition-colors"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" /></svg>
              Licencia MIT
            </a>
          </li>
        </ul>
      </div>

      <!-- Documentacion -->
      <div>
        <h3 class="text-sm font-semibold text-primary-300 uppercase tracking-wide">Documentación</h3>
        <ul class="mt-3 space-y-2" role="list">
          <li>
            <a href="#instalacion" class="text-sm text-primary-200 hover:text-white transition-colors">
              Guía de instalación
            </a>
          </li>
          <li>
            <a href="#funcionalidades" class="text-sm text-primary-200 hover:text-white transition-colors">
              Funcionalidades
            </a>
          </li>
          <li>
            <a href="#arquitectura" class="text-sm text-primary-200 hover:text-white transition-colors">
              Arquitectura
            </a>
          </li>
          <li>
            <a
              href={`${site.repository}/tree/main/Documents`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-primary-200 hover:text-white transition-colors"
            >
              Developer Docs
            </a>
          </li>
          <li>
            <a href="#historias" class="text-sm text-primary-200 hover:text-white transition-colors">
              Historias de usuario
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 border-t border-primary-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-primary-400">
      <span>&copy; {currentYear} {site.author}. Licencia {site.license}. Código abierto.</span>
      <button
        id="disclaimer-btn"
        type="button"
        class="inline-flex items-center gap-1.5 text-primary-400 hover:text-primary-200 transition-colors cursor-pointer text-sm"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
        Descargo de responsabilidad
      </button>
    </div>
  </div>
</footer>

<!-- Popup de descargo de responsabilidad -->
<div
  id="disclaimer-overlay"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="disclaimer-title"
>
  <div class="relative w-full max-w-lg rounded-2xl bg-white p-6 sm:p-8 shadow-2xl">
    <button
      id="disclaimer-close"
      type="button"
      class="absolute top-4 right-4 rounded-lg p-1.5 text-text-muted hover:text-text-primary hover:bg-surface-100 transition-colors"
      aria-label="Cerrar"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="flex items-center gap-3 mb-4">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-amber-100">
        <svg class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
        </svg>
      </div>
      <h2 id="disclaimer-title" class="text-lg font-semibold text-text-primary">Descargo de responsabilidad</h2>
    </div>

    <div class="space-y-3 text-sm text-text-secondary leading-relaxed">
      <p>
        <strong>PSPO Agent</strong> es una herramienta experimental que utiliza inteligencia artificial
        para generar artefactos de producto. <strong>No sustituye el criterio profesional</strong> de un
        Product Owner certificado ni de ningún rol de gestión de producto.
      </p>
      <p>
        El contenido generado (historias de usuario, criterios de aceptación, documentación) es una
        <strong>sugerencia automatizada</strong> que el usuario debe revisar, validar y aprobar antes de
        utilizarlo. El usuario es el único responsable de las decisiones de producto y de la
        información publicada en Trello, Notion o cualquier otro sistema.
      </p>
      <p>
        Este proyecto <strong>no está afiliado, asociado ni respaldado</strong> por Anthropic (Claude),
        Atlassian (Trello), Notion Labs ni Scrum.org (PSPO). Las marcas mencionadas pertenecen a sus respectivos
        propietarios.
      </p>
      <p>
        El software se proporciona <strong>"tal cual"</strong>, sin garantía de ningún tipo, expresa o
        implícita. Consulta la <a href=`${site.repository}/blob/main/LICENSE` target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 underline">licencia MIT</a> para más detalles.
      </p>
    </div>

    <div class="mt-6 text-right">
      <button
        id="disclaimer-accept"
        type="button"
        class="rounded-lg bg-primary-600 px-5 py-2 text-sm font-medium text-white hover:bg-primary-700 transition-colors"
      >
        Entendido
      </button>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('disclaimer-btn');
  const overlay = document.getElementById('disclaimer-overlay');
  const closeBtn = document.getElementById('disclaimer-close');
  const acceptBtn = document.getElementById('disclaimer-accept');

  function openDisclaimer() {
    overlay?.classList.remove('hidden');
    overlay?.classList.add('flex');
  }

  function closeDisclaimer() {
    overlay?.classList.add('hidden');
    overlay?.classList.remove('flex');
  }

  btn?.addEventListener('click', openDisclaimer);
  closeBtn?.addEventListener('click', closeDisclaimer);
  acceptBtn?.addEventListener('click', closeDisclaimer);
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closeDisclaimer();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !overlay?.classList.contains('hidden')) closeDisclaimer();
  });
</script>
